class Solution {
    public void rotateArray(int[] nums, int k) {
        k = k % nums.length;
        for(int j = 0; j < k; j++){
        int lst = nums[0];
        int idx = 0;
        for(int i = 1; i < nums.length; i++){
            nums[idx] = nums[i];
            idx++;
        }
        nums[nums.length-1] = lst;
        }
    }
}
